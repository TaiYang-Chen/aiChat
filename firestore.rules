rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    function isValidOptionalString(field, minLen, maxLen) {
      return !(field in request.resource.data) ||
             (request.resource.data[field] is string &&
              request.resource.data[field].size() >= minLen &&
              request.resource.data[field].size() <= maxLen);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return hasOnlyAllowedFields(['uid', 'email', 'displayName', 'photoURL', 'createdAt']) &&
             data.uid is string && data.uid.size() > 0 && data.uid.size() < 100 &&
             data.email is string && data.email.size() > 0 && data.email.size() < 100 &&
             isValidOptionalString('displayName', 0, 100) &&
             isValidOptionalString('photoURL', 0, 500) &&
             data.createdAt is timestamp;
    }

    function isValidChat(data) {
      return hasOnlyAllowedFields(['id', 'name', 'description', 'ownerId', 'createdAt', 'updatedAt']) &&
             data.id is string && data.id.size() > 0 && data.id.size() < 100 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             isValidOptionalString('description', 0, 500) &&
             data.ownerId is string && data.ownerId.size() > 0 && data.ownerId.size() < 100 &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    function isValidMessage(data) {
      return hasOnlyAllowedFields(['id', 'chatId', 'senderId', 'senderType', 'senderName', 'content', 'createdAt', 'status']) &&
             data.id is string && data.id.size() > 0 && data.id.size() < 100 &&
             data.chatId is string && data.chatId.size() > 0 && data.chatId.size() < 100 &&
             data.senderId is string && data.senderId.size() > 0 && data.senderId.size() < 100 &&
             data.senderType in ['user', 'ai'] &&
             isValidOptionalString('senderName', 0, 100) &&
             data.content is string && data.content.size() >= 0 && data.content.size() < 50000 &&
             data.createdAt is timestamp &&
             (!( 'status' in data ) || data.status in ['sending', 'sent', 'error', 'generating']);
    }

    function isValidChatMember(data) {
      return hasOnlyAllowedFields(['id', 'chatId', 'memberId', 'memberType', 'role', 'aiType', 'aiPrompt', 'name', 'joinedAt', 'aiProvider', 'aiModel', 'aiBaseUrl', 'aiApiKey']) &&
             data.id is string && data.id.size() > 0 && data.id.size() < 100 &&
             data.chatId is string && data.chatId.size() > 0 && data.chatId.size() < 100 &&
             data.memberId is string && data.memberId.size() > 0 && data.memberId.size() < 100 &&
             data.memberType in ['user', 'ai'] &&
             data.role in ['admin', 'member'] &&
             (!( 'aiType' in data ) || data.aiType in ['gpt', 'image', 'data', 'none']) &&
             (!( 'aiProvider' in data ) || data.aiProvider is string) &&
             (!( 'aiModel' in data ) || data.aiModel is string) &&
             (!( 'aiBaseUrl' in data ) || data.aiBaseUrl is string) &&
             (!( 'aiApiKey' in data ) || data.aiApiKey is string) &&
             isValidOptionalString('aiPrompt', 0, 5000) &&
             isValidOptionalString('name', 0, 100) &&
             data.joinedAt is timestamp;
    }

    // Check if user is a member of the chat
    function isChatMember(chatId) {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/chats/$(chatId)/members/$(request.auth.uid));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated(); // Allow reading basic profiles for chat
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && uidUnchanged();
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && uidNotModified();
    }

    match /chats/{chatId} {
      // Anyone authenticated can read chats they are a member of, or any chat if we want public chats.
      // For now, let's allow read if they are authenticated (so they can see the list of chats).
      // In a stricter app, we'd query where members array contains userId, but we use a subcollection.
      allow read: if isAuthenticated(); 
      allow create: if isAuthenticated() && isValidChat(request.resource.data) && request.resource.data.ownerId == request.auth.uid;
      allow update: if isAuthenticated() && isValidChat(request.resource.data) && resource.data.ownerId == request.auth.uid && request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if isAuthenticated() && resource.data.ownerId == request.auth.uid;

      match /messages/{messageId} {
        allow read: if isAuthenticated(); // Should be isChatMember(chatId) but for simplicity in prototype
        allow create: if isAuthenticated() && isValidMessage(request.resource.data);
        allow update: if isAuthenticated() && isValidMessage(request.resource.data) && (resource.data.senderId == request.auth.uid || resource.data.senderType == 'ai');
      }

      match /members/{memberId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && isValidChatMember(request.resource.data);
        allow update: if isAuthenticated() && isValidChatMember(request.resource.data);
        allow delete: if isAuthenticated();
      }
    }
  }
}
